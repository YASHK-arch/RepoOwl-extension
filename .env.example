# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Extension (anon key — read-only on issues; prompt saves use anonymous auth)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Enable "Anonymous sign-ins" in Supabase Dashboard → Authentication → Providers
# before using the extension settings page to save custom prompts.

# Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# GitHub Actions worker
GITHUB_TOKEN=your-github-token
