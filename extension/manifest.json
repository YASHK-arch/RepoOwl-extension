{
  "manifest_version": 3,
  "name": "RepoOwl",
  "version": "0.1.0",
  "description": "AI-powered issue insights and duplicate detection for GitHub repositories.",
  "permissions": ["storage", "activeTab", "alarms"],
  "host_permissions": [
    "https://github.com/*",
    "https://*.supabase.co/*"
  ],
  "icons": {
    "16": "icons/logo16.png",
    "48": "icons/logo48.png",
    "128": "icons/logo128.png"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "RepoOwl",
    "default_icon": {
      "16": "icons/logo16.png",
      "48": "icons/logo48.png",
      "128": "icons/logo128.png"
    }
  },
  "options_ui": {
    "page": "src/options/index.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*/*"],
      "js": ["sidebarCard.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://github.com/*/*/issues*", "https://github.com/*/*/issues/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
